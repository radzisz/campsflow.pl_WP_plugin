includes:
    - vendor/szepeviktor/phpstan-wordpress/extension.neon

parameters:
    level: 8
    paths:
        - src
        - campsflow.php
    phpVersion: 80200
    treatPhpDocTypesAsCertain: false

    excludePaths:
        - src/Presentation/ElementorIntegration.php
        - src/Presentation/ElementorWidget.php
        - src/Presentation/EventFieldWidget.php
        - src/Presentation/EventContactWidget.php
        - src/Presentation/EventDocumentsWidget.php
        - src/Presentation/EventLeadImageWidget.php
        - src/Presentation/EventLeadVideoWidget.php
        - src/Presentation/EventGalleryWidget.php
        - src/Presentation/EventTagsWidget.php
        - src/Presentation/EventAgeGroupWidget.php
        - src/Presentation/EventSessionsWidget.php
        - src/Presentation/SearchFilterWidget.php
        - src/Presentation/SearchFilterFieldWidget.php
        - src/Presentation/SearchSortWidget.php
        - src/Presentation/SearchResultsWidget.php
        - src/Presentation/EventMapWidget.php
        - src/Presentation/WpBakeryIntegration.php
        - src/Presentation/WpBakeryDynamicContent.php

    dynamicConstantNames:
        - CAMPSFLOW_PLUGIN_DIR
        - CAMPSFLOW_PLUGIN_URL
        - CAMPSFLOW_VERSION
        - ABSPATH

    ignoreErrors:
        # Plugin Update Checker — types not fully declared
        - '#Call to an undefined method YahnisElsts\\PluginUpdateChecker#'
        # WP constants defined at runtime — analysis runs without WP loaded
        - '#Constant CAMPSFLOW_PLUGIN_DIR not found#'
        # WP_Screen and WP_Term PHPDoc types differ from runtime nullability
        - '#Property WP_Screen::\$post_type .* on left side of \?\? is not nullable#'
        - '#Property WP_Term::\$name .* in isset\(\) is not nullable#'
        - '#Property WP_Term::\$slug .* in isset\(\) is not nullable#'
