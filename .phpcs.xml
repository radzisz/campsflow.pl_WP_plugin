<?xml version="1.0"?>
<ruleset name="Campsflow WP Plugin">
    <description>PSR-4 OOP plugin — check WP security rules, skip WP naming conventions</description>

    <file>src</file>
    <file>campsflow.php</file>

    <arg name="extensions" value="php"/>
    <arg name="colors"/>
    <arg value="sp"/>

    <config name="testVersion" value="8.1-"/>

    <!-- Only core WP security/escaping rules, not full WP style -->
    <rule ref="WordPress-Core">
        <!-- PSR-4 uses camelCase variables — skip WP snake_case requirement -->
        <exclude name="WordPress.NamingConventions.ValidVariableName.VariableNotSnakeCase"/>
        <exclude name="WordPress.NamingConventions.ValidVariableName.PropertyNotSnakeCase"/>
        <exclude name="WordPress.NamingConventions.ValidVariableName.UsedPropertyNotSnakeCase"/>
        <!-- PSR-4 uses camelCase methods -->
        <exclude name="WordPress.NamingConventions.ValidFunctionName.MethodNameInvalid"/>
        <!-- PSR-4 uses PascalCase file names -->
        <exclude name="WordPress.Files.FileName.NotHyphenatedLowercase"/>
        <exclude name="WordPress.Files.FileName.InvalidClassFileName"/>
        <!-- Modern PHP: no Yoda conditions -->
        <exclude name="WordPress.PHP.YodaConditions.NotYoda"/>
        <!-- Doc comments: skipped for OOP -->
        <exclude name="Squiz.Commenting.FileComment.Missing"/>
        <exclude name="Squiz.Commenting.ClassComment.Missing"/>
        <exclude name="Squiz.Commenting.FunctionComment.Missing"/>
        <exclude name="Squiz.Commenting.FunctionComment.MissingParamTag"/>
        <exclude name="Squiz.Commenting.FunctionComment.MissingReturn"/>
        <!-- Translator comments: not needed in plugin UI code -->
        <exclude name="WordPress.WP.I18n.MissingTranslatorsComment"/>
    </rule>
</ruleset>
